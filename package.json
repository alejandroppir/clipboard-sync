{
  "name": "clipboard-sync",
  "version": "1.0.0",
  "description": "Sincronizador de portapapeles",
  "main": "dist/main/main.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "generate-icon": "node scripts/generate-icon.mjs",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json && node -e \"const fs=require('fs');fs.mkdirSync('dist/renderer',{recursive:true});fs.copyFileSync('src/renderer/settings.html','dist/renderer/settings.html');fs.copyFileSync('src/renderer/settings.css','dist/renderer/settings.css');\"",
    "dev": "npm run build && electron .",
    "package": "npm run build && electron-builder --win portable",
    "release": "npm run build && electron-builder --win portable --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "firebase": "^9.22.2"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.6.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
